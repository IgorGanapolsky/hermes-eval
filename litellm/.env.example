# Copy to litellm/.env (gitignored), fill, and `set -a; . litellm/.env; set +a` before running the proxy.
LITELLM_MASTER_KEY=sk-hermes-local-dev      # any string; clients send it as the Bearer token
OPENROUTER_API_KEY=                          # already present in ~/.hermes/.env on this box

# Optional:
# ANTHROPIC_API_KEY=                         # if you want a Claude judge/fallback instead of OpenRouter
# DATABASE_URL=postgresql://user:pass@localhost:5432/litellm   # enables spend logs -> golden-set feed
